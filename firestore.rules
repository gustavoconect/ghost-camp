rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /categories/{categoryId} {
      allow read: if true; // Todos podem ver o catálogo
      allow write: if request.auth != null; // Apenas admin (logado)
    }

    match /equipments/{equipmentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /site_settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
